# Stellar Horizon API
HORIZON_API_URL=https://horizon-testnet.stellar.org
HORIZON_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Storage
DATA_DIR=./data
ARGUSCHAIN_DB_PATH=./data/arguschain.db
MODEL_DIR=./models

# Detection Configuration
ASSET_PAIR_WHITELIST=XLM/USDC,USDC/EUR,XLM/CNY
MIN_TRADE_VOLUME=100.0
RISK_SCORE_THRESHOLD=70

# ML Configuration
PRIMARY_MODEL=xgboost
SMOTE_ENABLED=true

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
ARGUSCHAIN_CORS_ALLOWED_ORIGINS=http://localhost:3000
ARGUSCHAIN_ADMIN_API_KEY=

# Soroban (Optional)
ARGUSCHAIN_SCORE_CONTRACT_ID=
ARGUSCHAIN_SERVICE_SECRET_KEY=
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_CIRCUIT_BREAKER_THRESHOLD=5

# ZK Proofs (Optional)
ZK_PROVING_ENABLED=false
ZK_MODEL_COMMITMENT_HASH=
ZK_PROVER_BINARY_PATH=./bin/zk_prover

# Drift Monitoring (Optional)
PSI_THRESHOLD=0.20
FEATURE_ARCHIVE_CUTOFF_DAYS=30
FEATURE_ARCHIVE_DIR=./data/feature_archive

# Logging
LOG_LEVEL=INFO
